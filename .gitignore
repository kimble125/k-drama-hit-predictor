# ========================================
# 🚨 Nielsen Korea 데이터 — 이용약관상 재배포 금지
# ========================================
# 닐슨 코리아 이용약관(https://www.nielsenkorea.co.kr/terms-of-use.asp)에
# 따라 수집된 원천 데이터는 재배포/업로드 금지.
# 크롤러(src/hit_predictor/data/collectors/nielsen.py)와
# 분석 결과(output/)는 공개 가능.
data/nielsen_weekly/*.csv
data/nielsen_weekly/*.json
!data/nielsen_weekly/.gitkeep

# 기타 수집 원시 데이터 (로컬 보관만)
data/raw/
data/*_raw.csv

# ========================================
# Python
# ========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 가상환경
venv/
env/
.venv/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# 테스트/커버리지
.coverage
.pytest_cache/
htmlcov/
.tox/

# 출력 (작은 JSON은 공개, 대용량은 제외)
output/*.png
output/*.pdf
output/*.xlsx
.claude/
